# Copy this file to .env.local and fill in all values

# NextAuth.js - Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable APIs: Google Sheets API, Google Drive API
# 4. Go to Credentials -> Create OAuth 2.0 Client ID
# 5. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Note: Users only need to grant basic profile access (openid, email, profile).
#       All Sheets and Drive operations are handled server-side via the service account below.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Sheets ID (the long ID from your spreadsheet URL)
# This is a single master spreadsheet owned/shared with the service account.
# Each user automatically gets their own tab inside it — no per-user setup required.
# 1. Create a new Google Sheet at https://sheets.google.com
# 2. Copy the ID from the URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
# 3. Share the sheet with the service account email (Editor access)
GOOGLE_SHEETS_ID=your-google-sheets-id

# Google Service Account Credentials (used to access the shared Google Sheet and Google Drive)
# This allows all authorized app users to read/write the wardrobe and upload images, regardless of
# who originally created the spreadsheet, without requiring users to grant Drive or Sheets permissions.
# 1. In Google Cloud Console, go to IAM & Admin -> Service Accounts
# 2. Create a service account and download the JSON key file
# 3. Enable both Google Sheets API and Google Drive API for your project
# 4. Share your Google Sheet with the service account email (Editor access)
# 5. Copy the client_email and private_key values from the JSON key file here
# Note: Wardrobe images are uploaded to the service account's Google Drive and made
#       publicly viewable so they can be displayed in the app. No extra Drive setup is needed;
#       the service account manages its own files using the drive.file scope.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Note: replace literal \n with actual newlines, or keep as-is if your platform handles it
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gemini API Key (Free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
